<%# app/views/devise/invitations/edit.html.erb %>
<%# Página de criação de senha após aceitar o convite %>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Criar senha — LogCell</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Syne:wght@700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0f14;
      --surface:   #13161e;
      --surface2:  #1a1e2a;
      --border:    rgba(255,255,255,0.07);
      --blue:      #3b82f6;
      --cyan:      #06b6d4;
      --text:      #e8eaf0;
      --muted:     rgba(255,255,255,0.4);
      --error:     #f87171;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      -webkit-font-smoothing: antialiased;
    }

    body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 100vh;
    }

    /* ── Left panel ─────────────────────────────── */
    .left {
      position: relative;
      background: linear-gradient(160deg, #0f2040 0%, #091628 60%, #050d1a 100%);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 48px;
      overflow: hidden;
    }

    .left::before {
      content: '';
      position: absolute;
      top: -100px;
      left: -100px;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(59,130,246,0.18) 0%, transparent 65%);
      pointer-events: none;
    }

    .left::after {
      content: '';
      position: absolute;
      bottom: -80px;
      right: -80px;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(6,182,212,0.12) 0%, transparent 65%);
      pointer-events: none;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
      z-index: 1;
    }

    .logo-mark {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--blue), var(--cyan));
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo-text {
      font-family: 'Syne', sans-serif;
      font-size: 24px;
      font-weight: 800;
      letter-spacing: -0.5px;
    }

    .left-content {
      position: relative;
      z-index: 1;
    }

    .left-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(59,130,246,0.15);
      border: 1px solid rgba(59,130,246,0.25);
      border-radius: 100px;
      padding: 6px 16px;
      font-size: 12px;
      font-weight: 500;
      color: #93c5fd;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 24px;
    }

    .left-headline {
      font-family: 'Syne', sans-serif;
      font-size: 42px;
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -1px;
      color: #fff;
      margin-bottom: 16px;
    }

    .left-sub {
      font-size: 16px;
      color: rgba(255,255,255,0.45);
      line-height: 1.65;
      max-width: 340px;
    }

    .features {
      display: flex;
      flex-direction: column;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .feature-item {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      color: rgba(255,255,255,0.5);
    }

    .feature-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--blue), var(--cyan));
      flex-shrink: 0;
    }

    /* ── Right panel ─────────────────────────────── */
    .right {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px;
      background: var(--bg);
    }

    .form-wrap {
      width: 100%;
      max-width: 400px;
    }

    .form-title {
      font-family: 'Syne', sans-serif;
      font-size: 28px;
      font-weight: 800;
      letter-spacing: -0.5px;
      margin-bottom: 8px;
    }

    .form-sub {
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 40px;
      line-height: 1.6;
    }

    /* User info card */
    .user-card {
      display: flex;
      align-items: center;
      gap: 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px 20px;
      margin-bottom: 36px;
    }

    .user-avatar {
      width: 44px;
      height: 44px;
      background: linear-gradient(135deg, var(--blue), var(--cyan));
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 18px;
      color: white;
      flex-shrink: 0;
    }

    .user-info-label {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 2px;
    }

    .user-info-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }

    .user-info-email {
      font-size: 13px;
      color: var(--muted);
    }

    /* Form fields */
    .field {
      margin-bottom: 20px;
    }

    .field label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: rgba(255,255,255,0.7);
      margin-bottom: 8px;
      letter-spacing: 0.2px;
    }

    .field-wrap {
      position: relative;
    }

    .field input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 44px 14px 16px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .field input:focus {
      border-color: rgba(59,130,246,0.5);
      box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    .field input::placeholder {
      color: rgba(255,255,255,0.2);
    }

    .toggle-eye {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--muted);
      display: flex;
      align-items: center;
      padding: 4px;
      transition: color 0.2s;
    }

    .toggle-eye:hover { color: var(--text); }

    /* Strength meter */
    .strength-wrap {
      margin-top: 10px;
    }

    .strength-bars {
      display: flex;
      gap: 4px;
      margin-bottom: 6px;
    }

    .strength-bar {
      height: 3px;
      flex: 1;
      background: rgba(255,255,255,0.08);
      border-radius: 10px;
      transition: background 0.3s;
    }

    .strength-bar.filled-weak   { background: #f87171; }
    .strength-bar.filled-fair   { background: #fb923c; }
    .strength-bar.filled-good   { background: #facc15; }
    .strength-bar.filled-strong { background: #4ade80; }

    .strength-label {
      font-size: 12px;
      color: var(--muted);
      transition: color 0.3s;
    }

    /* Error messages */
    .field-error {
      font-size: 12px;
      color: var(--error);
      margin-top: 6px;
    }

    .flash-error {
      background: rgba(248,113,113,0.1);
      border: 1px solid rgba(248,113,113,0.2);
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 13px;
      color: var(--error);
      margin-bottom: 24px;
    }

    /* Submit */
    .btn-submit {
      width: 100%;
      background: linear-gradient(135deg, var(--blue), #2563eb);
      border: none;
      border-radius: 12px;
      padding: 16px;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: white;
      cursor: pointer;
      margin-top: 8px;
      letter-spacing: 0.2px;
      box-shadow: 0 8px 32px rgba(59,130,246,0.3);
      transition: opacity 0.2s, transform 0.1s, box-shadow 0.2s;
    }

    .btn-submit:hover {
      opacity: 0.92;
      box-shadow: 0 12px 40px rgba(59,130,246,0.4);
    }

    .btn-submit:active { transform: scale(0.99); }

    @media (max-width: 768px) {
      body { grid-template-columns: 1fr; }
      .left { display: none; }
      .right { padding: 32px 24px; }
    }
  </style>
</head>
<body>

  <!-- Left decorative panel -->
  <div class="left">
    <div class="logo">
      <div class="logo-mark">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
          <path d="M5 11h12M11 5v12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="logo-text">LogCell</span>
    </div>

    <div class="left-content">
      <div class="left-label">Bem-vindo à plataforma</div>
      <h1 class="left-headline">Crie sua<br>senha de<br>acesso.</h1>
      <p class="left-sub">Você está a um passo de acessar o sistema de gestão da sua loja.</p>
    </div>

    <div class="features">
      <div class="feature-item">
        <div class="feature-dot"></div>
        Controle de estoque em tempo real
      </div>
      <div class="feature-item">
        <div class="feature-dot"></div>
        Gestão de vendas e financeiro
      </div>
      <div class="feature-item">
        <div class="feature-dot"></div>
        Relatórios e análises detalhadas
      </div>
    </div>
  </div>

  <!-- Right form panel -->
  <div class="right">
    <div class="form-wrap">

      <h2 class="form-title">Defina sua senha</h2>
      <p class="form-sub">Crie uma senha segura para proteger sua conta no LogCell.</p>

      <!-- User info -->
      <div class="user-card">
        <div class="user-avatar"><%= resource.name.first.upcase rescue "?" %></div>
        <div>
          <div class="user-info-label">Criando conta para</div>
          <div class="user-info-name"><%= resource.name %></div>
          <div class="user-info-email"><%= resource.email %></div>
        </div>
      </div>

      <!-- Flash errors -->
      <% if resource.errors.any? %>
        <div class="flash-error">
          <% resource.errors.full_messages.each do |msg| %>
            <div>• <%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <%= form_for resource, as: resource_name, url: invitation_path(resource_name), html: { method: :put } do |f| %>
        <%= f.hidden_field :invitation_token, value: @token %>

        <div class="field">
          <label for="password">Nova senha</label>
          <div class="field-wrap">
            <%= f.password_field :password,
                  id: "password",
                  placeholder: "Mínimo 8 caracteres",
                  autocomplete: "new-password",
                  oninput: "checkStrength(this.value)" %>
            <button type="button" class="toggle-eye" onclick="togglePass('password', this)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
          <div class="strength-wrap">
            <div class="strength-bars">
              <div class="strength-bar" id="b1"></div>
              <div class="strength-bar" id="b2"></div>
              <div class="strength-bar" id="b3"></div>
              <div class="strength-bar" id="b4"></div>
            </div>
            <span class="strength-label" id="strength-label">Digite sua senha</span>
          </div>
        </div>

        <div class="field">
          <label for="password_confirmation">Confirmar senha</label>
          <div class="field-wrap">
            <%= f.password_field :password_confirmation,
                  id: "password_confirmation",
                  placeholder: "Repita a senha",
                  autocomplete: "new-password" %>
            <button type="button" class="toggle-eye" onclick="togglePass('password_confirmation', this)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <%= f.submit "Criar minha senha e entrar →", class: "btn-submit" %>
      <% end %>

    </div>
  </div>

  <script>
    function togglePass(id, btn) {
      const input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
    }

    function checkStrength(val) {
      const bars = ['b1','b2','b3','b4'].map(id => document.getElementById(id));
      const label = document.getElementById('strength-label');
      bars.forEach(b => b.className = 'strength-bar');

      if (!val) { label.textContent = 'Digite sua senha'; label.style.color = ''; return; }

      let score = 0;
      if (val.length >= 8)  score++;
      if (val.length >= 12) score++;
      if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;

      const levels = [
        { cls: 'filled-weak',   text: 'Fraca',   color: '#f87171' },
        { cls: 'filled-fair',   text: 'Regular', color: '#fb923c' },
        { cls: 'filled-good',   text: 'Boa',     color: '#facc15' },
        { cls: 'filled-strong', text: 'Forte',   color: '#4ade80' },
      ];

      const lvl = levels[score - 1] || levels[0];
      for (let i = 0; i < score; i++) bars[i].classList.add(lvl.cls);
      label.textContent = lvl.text;
      label.style.color = lvl.color;
    }
  </script>
</body>
</html>
