<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Log Cell" %></title>
    <meta name="description" content="Log Cell — Acessórios e eletrônicos com o melhor preço em Barueri/SP">
    <meta name="keywords" content="acessórios, eletrônicos, capinhas, cabos, fones, games, barueri">
    <meta property="og:title" content="Log Cell">
    <meta property="og:description" content="Acessórios e eletrônicos com o melhor preço">
    <meta property="og:type" content="website">
    <link rel="canonical" href="https://logcell.xyz">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="<%= asset_path('logotipo.png') %>" type="image/png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg: #080d17; --sf: #0f1624; --sf2: #162033;
        --bd: rgba(255,255,255,0.07); --bd2: rgba(255,255,255,0.14);
        --cy: #22d3ee; --gr: #34d399; --tx: #f1f5f9; --mu: #64748b;
      }
      html, body { background: var(--bg); color: var(--tx); font-family: 'Plus Jakarta Sans', sans-serif; min-height: 100vh; }
      body { display: flex; flex-direction: column; min-height: 100vh; }
      .lp-nav {
        position: sticky; top: 0; z-index: 100;
        background: var(--sf); border-bottom: 1px solid var(--bd);
        padding: 0 24px; height: 56px;
        display: flex; align-items: center; justify-content: space-between;
      }
      .lp-nav-logo { display: flex; align-items: center; }
      .lp-nav-logo img { height: 32px; width: auto; }
      .lp-nav-actions { display: flex; gap: 14px; align-items: center; }
      .lp-nav-link {
        color: var(--mu); font-size: 18px; text-decoration: none;
        transition: color 0.15s;
      }
      .lp-nav-link:hover { color: var(--cy); }
      .lp-btn-admin {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; background: var(--cy); color: #08111f;
        font-weight: 700; font-size: 13px; border-radius: 8px;
        text-decoration: none; transition: opacity 0.15s;
      }
      .lp-btn-admin:hover { opacity: 0.85; color: #08111f; }
      .lp-hero {
        background: linear-gradient(160deg, #0f1624 0%, #080d17 100%);
        border-bottom: 1px solid var(--bd);
        padding: 48px 24px 32px; text-align: center;
      }
      .lp-hero-inner { max-width: 900px; margin: 0 auto; }
      .lp-hero-sub { color: var(--mu); font-size: 15px; margin-bottom: 28px; }
      .lp-cats { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
      .lp-cat {
        padding: 6px 14px; border-radius: 20px;
        border: 1px solid var(--bd2); background: var(--sf2);
        color: var(--mu); font-size: 12px; font-weight: 600;
        text-decoration: none; transition: all 0.15s; cursor: pointer;
      }
      .lp-cat:hover, .lp-cat.active {
        background: rgba(34,211,238,0.15); border-color: var(--cy); color: var(--cy);
      }
      .lp-products { flex: 1; padding: 32px 24px; max-width: 1280px; width: 100%; margin: 0 auto; }
      .lp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
      .lp-card {
        background: var(--sf); border: 1px solid var(--bd);
        border-radius: 12px; overflow: hidden;
        display: flex; flex-direction: column;
        transition: border-color 0.2s, transform 0.2s;
      }
      .lp-card:hover { border-color: var(--bd2); transform: translateY(-2px); }
      .lp-card-img {
        background: var(--sf2); height: 180px;
        display: flex; align-items: center; justify-content: center;
        border-bottom: 1px solid var(--bd); overflow: hidden;
      }
      .lp-card-photo { width: 100%; height: 100%; object-fit: cover; }
      .lp-card-icon { font-size: 56px; }
      .lp-card-body { padding: 14px; display: flex; flex-direction: column; gap: 4px; flex: 1; }
      .lp-card-cat { font-size: 10px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; color: var(--cy); }
      .lp-card-name { font-size: 14px; font-weight: 600; color: var(--tx); line-height: 1.3; }
      .lp-card-brand { font-size: 11px; color: var(--mu); }
      .lp-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--bd); }
      .lp-card-price { font-size: 16px; font-weight: 700; color: var(--gr); font-family: 'Syne', sans-serif; }
      .lp-card-stock { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 5px; }
      .lp-card-stock.in  { background: rgba(52,211,153,0.15); color: #34d399; }
      .lp-card-stock.out { background: rgba(248,113,113,0.15); color: #f87171; }
      .lp-empty { grid-column: 1/-1; text-align: center; padding: 60px 0; color: var(--mu); }
      .lp-empty span { font-size: 48px; display: block; margin-bottom: 12px; }
      .lp-footer {
        background: var(--sf); border-top: 1px solid var(--bd);
        padding: 16px 24px; text-align: center;
        color: var(--mu); font-size: 12px; margin-top: auto;
      }
      @media (max-width: 600px) {
        .lp-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
        .lp-hero { padding: 32px 16px 24px; }
        .lp-card-img { height: 140px; }
      }
    </style>
  </head>

  <body>
    <nav class="lp-nav">
      <a href="/" class="lp-nav-logo">
        <%= image_tag "logotipo.png", alt: "Log Cell" %>
      </a>
      <div class="lp-nav-actions">
        <a href="https://www.instagram.com/log_cell_acessorios/" target="_blank" class="lp-nav-link">
          <i class="fab fa-instagram"></i>
        </a>
        <a href="https://wa.me/5511989528468" target="_blank" class="lp-nav-link">
          <i class="fab fa-whatsapp"></i>
        </a>
        <a href="https://share.google/6n9em7vRS4hrLmz2x" target="_blank" class="lp-nav-link">
          <i class="fas fa-map-marker-alt"></i>
        </a>
        <%= link_to "/admin", class: "lp-btn-admin" do %>
          <i class="fas fa-lock"></i> Área Admin
        <% end %>
      </div>
    </nav>

    <%= yield %>

    <footer class="lp-footer">
      &copy; <%= Date.current.year %> Log Cell — Todos os direitos reservados.
    </footer>
  </body>
</html>
